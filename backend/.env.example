# Mr. Wiggles Backend Configuration

# Server
PORT=3000
HOST=localhost

# Demo mode (set to true to use synthetic data without hardware)
DEMO_MODE=true
DEMO_SIGNAL_COUNT=5
DEMO_UPDATE_RATE_HZ=60

# SDR Hardware (set DEMO_MODE=false to use real hardware)
# Supported: hackrf, rtlsdr, auto
SDR_TYPE=auto
SDR_SAMPLE_RATE=2000000
SDR_CENTER_FREQ=2437000000
SDR_GAIN=20

# Signal Detection
RSSI_THRESHOLD=-60
DOA_SMOOTHING=0.3
SCAN_DWELL_MS=100

# WebSocket
WS_BROADCAST_RATE_HZ=60
